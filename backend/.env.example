# Application
APP_NAME=SoldierIQ Backend
ENVIRONMENT=development
DEBUG=false

# Database
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=soldieriq

# Redis Configuration (for Celery background tasks)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

SECRET_KEY=soldieriq-super-secret-key-change-in-production-use-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Vector Database
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=soldieriq-documents

# LLM APIs
OPENAI_API_KEY=your_openai_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
GROQ_API_KEY=your_groq_api_key
# iDrive E2 Storage
IDRIVEE2_ENDPOINT_URL=https://your-region.idrivee2-2.com
IDRIVEE2_ACCESS_KEY_ID=your_idrivee2_access_key
IDRIVEE2_SECRET_ACCESS_KEY=your_idrivee2_secret_key
IDRIVEE2_BUCKET_NAME=soldieriq-documents

# File Storage Settings
PRESIGNED_URL_EXPIRATION=604800  # 7 days in seconds (maximum)

# Document Processing APIs
UNSTRUCTURED_API_KEY=your_unstructured_api_key
UNSTRUCTURED_API_URL=
ELEVENLABS_API_KEY=

# Cognee (knowledge graph + semantic memory — replaces Apache AGE)
# LLM used by Cognee for both extraction (cognify) and search
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=${OPENAI_API_KEY}

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Vector store — pgvector on the Postgres we already have (use a dedicated DB)
VECTOR_DB_PROVIDER=pgvector
VECTOR_DB_URL=localhost
VECTOR_DB_PORT=5432
VECTOR_DB_USERNAME=postgres
VECTOR_DB_PASSWORD=postgres
VECTOR_DB_NAME=cognee_vectors

# Graph store — FalkorDB (replaces Apache AGE)
GRAPH_DATABASE_PROVIDER=falkor
GRAPH_DATABASE_URL=localhost
GRAPH_DATABASE_PORT=6379

# Cognee relational/metadata store — Postgres (dedicated DB)
DB_PROVIDER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=cognee_metadata


